# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onesubscribe"

# App Security
JWT_SECRET="generate-a-secure-random-32-character-secret"
ENCRYPTION_KEY="32-byte-hex-key-for-aes-encryption"

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"

# Pakasir Payment Gateway
PAKASIR_API_KEY="your-pakasir-api-key"
PAKASIR_WEBHOOK_SECRET="your-pakasir-webhook-secret"

# WhatsApp Gateway (Fonnte)
FONNTE_TOKEN="your-fonnte-token"

# Email Service (Resend)
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="OneSubscribe <noreply@onesubscribe.com>"

# Storage Gateway (RustFS S3-compatible, self-hosted)
RUSTFS_ENDPOINT="https://rustfs.yourdomain.com"
RUSTFS_ACCESS_KEY="rustfs-access-key"
RUSTFS_SECRET_KEY="rustfs-secret-key"
RUSTFS_BUCKET="onesubscribe"
