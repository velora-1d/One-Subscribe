# Database Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onesubscribe"

# App Security
JWT_SECRET="generate-a-secure-random-32-character-secret"
ENCRYPTION_KEY="32-byte-hex-key-for-aes-encryption"

# Pakasir Payment Gateway Configuration
PAKASIR_ENV="sandbox"
PAKASIR_SLUG="your-pakasir-slug"
PAKASIR_API_KEY="your-pakasir-api-key"
PAKASIR_CALLBACK_URL="your-pakasir-callback-url"

# Midtrans Payment Gateway Configuration
MIDTRANS_ENV="sandbox"
MIDTRANS_SANDBOX_MERCHANT_ID="your-midtrans-sandbox-merchant-id"
MIDTRANS_SANDBOX_CLIENT_KEY="your-midtrans-sandbox-client-key"
MIDTRANS_SANDBOX_SERVER_KEY="your-midtrans-sandbox-server-key"
MIDTRANS_PRODUCTION_MERCHANT_ID="your-midtrans-production-merchant-id"
MIDTRANS_PRODUCTION_CLIENT_KEY="your-midtrans-production-client-key"
MIDTRANS_PRODUCTION_SERVER_KEY="your-midtrans-production-server-key"

# WhatsApp Gateway (Fonnte)
FONNTE_TOKEN="your-fonnte-token"

# Email Service (Resend)
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="OneSubscribe <noreply@onesubscribe.com>"

# Storage Gateway (RustFS S3-compatible, self-hosted)
RUSTFS_ENDPOINT="https://rustfs.yourdomain.com"
RUSTFS_ACCESS_KEY="rustfs-access-key"
RUSTFS_SECRET_KEY="rustfs-secret-key"
RUSTFS_BUCKET="onesubscribe"
